{
  "scenario_id": "ui_full_game_completes",
  "version": 3,
  "description": "Verify a full 30-turn game completes: session marked completed, game-over screen visible, turn counter past 30",
  "harness_scene": "res://validation/harnesses/ui_game_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 700 },
    { "op": "checkpoint", "name": "final" },
    {
      "op": "assert_value",
      "checkpoint": "final",
      "path": "harness_state.session_status",
      "comparator": "eq",
      "expected": "completed"
    },
    {
      "op": "assert_value",
      "checkpoint": "final",
      "path": "harness_state.game_over_visible",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "final",
      "path": "harness_state.current_turn",
      "comparator": "gt",
      "expected": 30
    },
    { "op": "quit" }
  ]
}
