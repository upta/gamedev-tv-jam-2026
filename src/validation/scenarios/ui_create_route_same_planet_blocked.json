{
  "scenario_id": "ui_create_route_same_planet_blocked",
  "version": 3,
  "description": "Verify that setting origin to earth then opening the dest selector excludes earth from the list (11 items instead of 12)",
  "harness_scene": "res://validation/harnesses/ui_create_route_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 55 },
    { "op": "checkpoint", "name": "modal_open" },
    {
      "op": "assert_value",
      "checkpoint": "modal_open",
      "path": "harness_state.create_route_modal_open",
      "comparator": "eq",
      "expected": true
    },
    { "op": "wait_frames", "frames": 15 },
    { "op": "checkpoint", "name": "origin_set" },
    {
      "op": "assert_value",
      "checkpoint": "origin_set",
      "path": "harness_state.origin_id",
      "comparator": "eq",
      "expected": "earth"
    },
    { "op": "wait_frames", "frames": 15 },
    { "op": "checkpoint", "name": "dest_popup_open" },
    {
      "op": "assert_value",
      "checkpoint": "dest_popup_open",
      "path": "harness_state.selection_popup_visible",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "dest_popup_open",
      "path": "harness_state.selection_popup_item_count",
      "comparator": "eq",
      "expected": 11
    },
    {
      "op": "assert_value",
      "checkpoint": "dest_popup_open",
      "path": "harness_state.origin_id",
      "comparator": "eq",
      "expected": "earth"
    },
    { "op": "quit" }
  ]
}
