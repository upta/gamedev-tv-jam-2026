{
  "scenario_id": "economy_demand_zero_at_extreme_price",
  "version": 3,
  "description": "Verify price factor drops to 0.0 at 2x suggested price — extreme pricing kills demand completely",
  "harness_scene": "res://validation/harnesses/simulation_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "checkpoint", "name": "initial" },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.metrics.price_factor_at_2x_suggested",
      "comparator": "eq",
      "expected": 0.0
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.metrics.price_factor_at_10x_suggested",
      "comparator": "eq",
      "expected": 0.0
    },
    { "op": "quit" }
  ]
}
