{
  "scenario_id": "session_all_carriers_active",
  "version": 3,
  "description": "After 10 turns all NPC carriers have at least one active route",
  "harness_scene": "res://validation/harnesses/game_session_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "mid_game" },
    {
      "op": "assert_value",
      "checkpoint": "mid_game",
      "path": "harness_state.carriers.npc_1.route_count",
      "comparator": "gte",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "mid_game",
      "path": "harness_state.carriers.npc_2.route_count",
      "comparator": "gte",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "mid_game",
      "path": "harness_state.carriers.npc_3.route_count",
      "comparator": "gte",
      "expected": 1
    },
    { "op": "quit" }
  ]
}
