{
  "scenario_id": "session_all_carriers_active",
  "version": 3,
  "description": "After 10 turns the session should have broad route activity even if one cautious NPC is still ramping up",
  "harness_scene": "res://validation/harnesses/game_session_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 15 },
    { "op": "checkpoint", "name": "mid_game" },
    {
      "op": "assert_value",
      "checkpoint": "mid_game",
      "path": "harness_state.metrics.carriers_with_active_routes",
      "comparator": "gte",
      "expected": 3
    },
    {
      "op": "assert_value",
      "checkpoint": "mid_game",
      "path": "harness_state.metrics.npcs_with_active_routes",
      "comparator": "gte",
      "expected": 2
    },
    {
      "op": "assert_value",
      "checkpoint": "mid_game",
      "path": "harness_state.metrics.total_active_routes",
      "comparator": "gte",
      "expected": 3
    },
    { "op": "quit" }
  ]
}
