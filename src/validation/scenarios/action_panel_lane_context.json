{
  "scenario_id": "action_panel_lane_context",
  "version": 3,
  "description": "Verify ActionPanel switches to lane context with correct lane ID and label",
  "harness_scene": "res://validation/harnesses/action_panel_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 80 },
    { "op": "checkpoint", "name": "lane" },
    {
      "op": "assert_value",
      "checkpoint": "lane",
      "path": "harness_state.current_context",
      "comparator": "eq",
      "expected": "lane"
    },
    {
      "op": "assert_value",
      "checkpoint": "lane",
      "path": "harness_state.selected_lane_id",
      "comparator": "eq",
      "expected": "sol_earth_mars"
    },
    {
      "op": "assert_value",
      "checkpoint": "lane",
      "path": "harness_state.context_label_text",
      "comparator": "starts_with",
      "expected": "Lane:"
    },
    {
      "op": "assert_value",
      "checkpoint": "lane",
      "path": "harness_state.form_child_count",
      "comparator": "gt",
      "expected": 0
    },
    { "op": "quit" }
  ]
}
