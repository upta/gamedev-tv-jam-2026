{
  "scenario_id": "action_panel_clear_intent",
  "version": 3,
  "description": "Verify clearing intent resets all pending action counts to zero",
  "harness_scene": "res://validation/harnesses/action_panel_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 120 },
    { "op": "checkpoint", "name": "before_clear" },
    {
      "op": "assert_value",
      "checkpoint": "before_clear",
      "path": "harness_state.pending_summary.slot_bids",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "before_clear",
      "path": "harness_state.pending_summary.ship_orders",
      "comparator": "eq",
      "expected": 1
    },
    { "op": "wait_frames", "frames": 20 },
    { "op": "checkpoint", "name": "after_clear" },
    {
      "op": "assert_value",
      "checkpoint": "after_clear",
      "path": "harness_state.pending_summary.slot_bids",
      "comparator": "eq",
      "expected": 0
    },
    {
      "op": "assert_value",
      "checkpoint": "after_clear",
      "path": "harness_state.pending_summary.ship_orders",
      "comparator": "eq",
      "expected": 0
    },
    {
      "op": "assert_value",
      "checkpoint": "after_clear",
      "path": "harness_state.pending_summary.route_creates",
      "comparator": "eq",
      "expected": 0
    },
    { "op": "quit" }
  ]
}
