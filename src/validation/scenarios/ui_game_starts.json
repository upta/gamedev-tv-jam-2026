{
  "scenario_id": "ui_game_starts",
  "version": 3,
  "description": "Verify GameScene initializes with correct default state: session running, turn 1, starting cash, UI visible, game-over hidden",
  "harness_scene": "res://validation/harnesses/ui_game_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 15 },
    { "op": "checkpoint", "name": "initial" },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.session_status",
      "comparator": "eq",
      "expected": "running"
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.current_turn",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.player_cash",
      "comparator": "eq",
      "expected": 3000.0
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.ui_visible",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.game_over_visible",
      "comparator": "eq",
      "expected": false
    },
    { "op": "quit" }
  ]
}
