{
  "scenario_id": "sim_initial_state",
  "version": 3,
  "description": "Verify game initializes with correct structural state (carrier count, galaxy topology)",
  "harness_scene": "res://validation/harnesses/simulation_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "checkpoint", "name": "initial" },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carrier_count",
      "comparator": "eq",
      "expected": 4
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.galaxy.planet_count",
      "comparator": "eq",
      "expected": 12
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.demand_table_initialized",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.metrics.total_carriers",
      "comparator": "eq",
      "expected": 4
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.player.slots.earth",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.player.slots.mars",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.npc_1.slots.earth",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.npc_1.slots.centauri_prime",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.npc_2.slots.earth",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.npc_2.slots.titan",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.npc_3.slots.earth",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.carriers.npc_3.slots.wolf_station",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.metrics.earth_mars_cargo_price_ratio",
      "comparator": "eq",
      "expected": 0.5
    },
    {
      "op": "assert_pipeline",
      "sources": {
        "cargo": {
          "kind": "checkpoint",
          "checkpoint": "initial",
          "path": "harness_state.metrics.earth_mars_forward_cargo_demand"
        },
        "passenger": {
          "kind": "checkpoint",
          "checkpoint": "initial",
          "path": "harness_state.metrics.earth_mars_forward_passenger_demand"
        }
      },
      "pipeline": [
        {
          "op": "subtract",
          "inputs": ["cargo", "passenger"],
          "as": "cargo_surplus"
        }
      ],
      "assert": {
        "actual": "cargo_surplus",
        "comparator": "gt",
        "expected": 0
      }
    },
    { "op": "quit" }
  ]
}
