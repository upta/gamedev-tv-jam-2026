{
  "scenario_id": "economy_frequency_speed_limited",
  "version": 3,
  "description": "Verify game runs with speed-based frequency constraints — player creates route and game does not crash with new frequency logic",
  "harness_scene": "res://validation/harnesses/simulation_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "checkpoint", "name": "after_turns" },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.turns_resolved",
      "comparator": "gte",
      "expected": 3
    },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.carrier_count",
      "comparator": "eq",
      "expected": 4
    },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.last_result.game_over",
      "comparator": "eq",
      "expected": false
    },
    { "op": "quit" }
  ]
}
