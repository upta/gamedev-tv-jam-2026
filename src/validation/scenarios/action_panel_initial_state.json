{
  "scenario_id": "action_panel_initial_state",
  "version": 3,
  "description": "Verify ActionPanel initializes in default context with ship order form and empty pending summary",
  "harness_scene": "res://validation/harnesses/action_panel_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "checkpoint", "name": "initial" },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.current_context",
      "comparator": "eq",
      "expected": "none"
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.context_label_text",
      "comparator": "eq",
      "expected": "General Actions"
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.selected_planet_id",
      "comparator": "eq",
      "expected": ""
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.selected_lane_id",
      "comparator": "eq",
      "expected": ""
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.form_child_count",
      "comparator": "gt",
      "expected": 0
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.pending_summary.slot_bids",
      "comparator": "eq",
      "expected": 0
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.pending_summary.ship_orders",
      "comparator": "eq",
      "expected": 0
    },
    { "op": "quit" }
  ]
}
