{
  "scenario_id": "star_map_initial_state",
  "version": 3,
  "description": "Verify StarMap initializes with correct planet/lane counts from default galaxy",
  "harness_scene": "res://validation/harnesses/star_map_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "checkpoint", "name": "initial" },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.planet_node_count",
      "comparator": "eq",
      "expected": 12
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.lane_line_count",
      "comparator": "eq",
      "expected": 15
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.route_line_count",
      "comparator": "eq",
      "expected": 0
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.selected_planet_id",
      "comparator": "eq",
      "expected": ""
    },
    {
      "op": "assert_value",
      "checkpoint": "initial",
      "path": "harness_state.selected_lane_id",
      "comparator": "eq",
      "expected": ""
    },
    { "op": "quit" }
  ]
}
