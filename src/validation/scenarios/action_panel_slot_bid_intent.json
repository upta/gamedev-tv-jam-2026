{
  "scenario_id": "action_panel_slot_bid_intent",
  "version": 3,
  "description": "Verify pending summary reflects a slot bid after submission",
  "harness_scene": "res://validation/harnesses/action_panel_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 60 },
    { "op": "checkpoint", "name": "after_bid" },
    {
      "op": "assert_value",
      "checkpoint": "after_bid",
      "path": "harness_state.pending_summary.slot_bids",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "after_bid",
      "path": "harness_state.pending_summary.route_creates",
      "comparator": "eq",
      "expected": 0
    },
    { "op": "quit" }
  ]
}
