{
  "scenario_id": "economy_cost_scales_with_frequency",
  "version": 3,
  "description": "Verify operating cost increases when route frequency is higher — player route on earth-mars with freq 1 should have non-zero operating cost",
  "harness_scene": "res://validation/harnesses/simulation_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 2 },
    { "op": "checkpoint", "name": "after_turns" },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.carriers.player.route_count",
      "comparator": "gte",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.carriers.player.route_costs.0.operating_cost",
      "comparator": "gt",
      "expected": 0.0
    },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.carriers.player.route_costs.0.frequency",
      "comparator": "gte",
      "expected": 1
    },
    { "op": "quit" }
  ]
}
