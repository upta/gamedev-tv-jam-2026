{
  "scenario_id": "ui_order_ship_flow",
  "version": 3,
  "description": "Verify the order ship flow: open ships modal, open order ship modal, place an order, verify pending order exists and modal returns to ships",
  "harness_scene": "res://validation/harnesses/ui_order_ship_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 25 },
    { "op": "checkpoint", "name": "ships_modal_open" },
    {
      "op": "assert_value",
      "checkpoint": "ships_modal_open",
      "path": "harness_state.ships_modal_open",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "ships_modal_open",
      "path": "harness_state.active_modal",
      "comparator": "eq",
      "expected": "ships"
    },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "order_modal_open" },
    {
      "op": "assert_value",
      "checkpoint": "order_modal_open",
      "path": "harness_state.order_ship_modal_open",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "order_modal_open",
      "path": "harness_state.ships_modal_open",
      "comparator": "eq",
      "expected": false
    },
    { "op": "wait_frames", "frames": 25 },
    { "op": "checkpoint", "name": "after_order" },
    {
      "op": "assert_value",
      "checkpoint": "after_order",
      "path": "harness_state.pending_ship_orders",
      "comparator": "gt",
      "expected": 0
    },
    {
      "op": "assert_value",
      "checkpoint": "after_order",
      "path": "harness_state.order_ship_modal_open",
      "comparator": "eq",
      "expected": false
    },
    {
      "op": "assert_value",
      "checkpoint": "after_order",
      "path": "harness_state.ships_modal_open",
      "comparator": "eq",
      "expected": true
    },
    { "op": "quit" }
  ]
}
