{
  "scenario_id": "npc_creates_routes",
  "version": 3,
  "description": "After 5 turns at least 2 NPCs have created active routes",
  "harness_scene": "res://validation/harnesses/game_session_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "after_5" },
    {
      "op": "assert_value",
      "checkpoint": "after_5",
      "path": "harness_state.metrics.total_routes_created",
      "comparator": "gte",
      "expected": 2
    },
    { "op": "quit" }
  ]
}
