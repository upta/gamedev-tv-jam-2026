{
  "scenario_id": "ui_routes_modal_shows_create_button",
  "version": 3,
  "description": "Verify the routes modal contains a Create Route button and no inline create form",
  "harness_scene": "res://validation/harnesses/ui_game_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 210 },
    { "op": "checkpoint", "name": "routes_open" },
    {
      "op": "assert_value",
      "checkpoint": "routes_open",
      "path": "harness_state.active_modal",
      "comparator": "eq",
      "expected": "routes"
    },
    {
      "op": "assert_value",
      "checkpoint": "routes_open",
      "path": "harness_state.create_route_modal_open",
      "comparator": "eq",
      "expected": false
    },
    { "op": "quit" }
  ]
}
