{
  "scenario_id": "sim_financials",
  "version": 3,
  "description": "Verify financial processing runs — player has a route and cash changes from initial 3000",
  "harness_scene": "res://validation/harnesses/simulation_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 2 },
    { "op": "checkpoint", "name": "after_turns" },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.carriers.player.route_count",
      "comparator": "gte",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.carriers.player.cash",
      "comparator": "neq",
      "expected": 3000.0
    },
    {
      "op": "assert_value",
      "checkpoint": "after_turns",
      "path": "harness_state.last_result.game_over",
      "comparator": "eq",
      "expected": false
    },
    { "op": "quit" }
  ]
}
