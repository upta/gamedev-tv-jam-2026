{
  "scenario_id": "sim_turn_advances",
  "version": 3,
  "description": "Verify turns resolve and advance the simulation correctly",
  "harness_scene": "res://validation/harnesses/simulation_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "checkpoint", "name": "before" },
    { "op": "wait_frames", "frames": 1 },
    { "op": "checkpoint", "name": "after" },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.turns_resolved",
      "comparator": "eq",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.current_turn",
      "comparator": "eq",
      "expected": 2
    },
    {
      "op": "assert_pipeline",
      "sources": {
        "before_cash": { "kind": "checkpoint", "checkpoint": "before", "path": "metrics.player_cash" },
        "after_cash": { "kind": "checkpoint", "checkpoint": "after", "path": "metrics.player_cash" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["before_cash", "after_cash"], "as": "cash_delta" }
      ],
      "assert": {
        "actual": "cash_delta",
        "comparator": "neq",
        "expected": 0
      }
    },
    { "op": "quit" }
  ]
}
