{
  "scenario_id": "sim_turn_advances",
  "version": 3,
  "description": "Verify turns resolve and advance the simulation — turn count increases between checkpoints",
  "harness_scene": "res://validation/harnesses/simulation_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "checkpoint", "name": "before" },
    { "op": "wait_frames", "frames": 1 },
    { "op": "checkpoint", "name": "after" },
    {
      "op": "assert_pipeline",
      "sources": {
                "before_turns": { "kind": "checkpoint", "checkpoint": "before", "path": "harness_state.turns_resolved" },
                "after_turns": { "kind": "checkpoint", "checkpoint": "after", "path": "harness_state.turns_resolved" }
      },
      "pipeline": [
                { "op": "subtract", "inputs": ["after_turns", "before_turns"], "as": "turns_delta" }
      ],
      "assert": {
                "actual": "turns_delta",
                "comparator": "gte",
                "expected": 1
      }
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.turns_resolved",
      "comparator": "gte",
      "expected": 1
    },
    { "op": "quit" }
  ]
}
