{
  "scenario_id": "ui_player_creates_route",
  "version": 3,
  "description": "Verify player slot bid queues as a pending action and is consumed after the next turn resolves",
  "harness_scene": "res://validation/harnesses/ui_game_harness.tscn",
  "done_contract": {},
  "artifact_contract": {
    "required_files": ["summary.json", "event_log.json", "scene_tree.json", "console.log"],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    { "op": "load_harness" },
    { "op": "wait_frames", "frames": 85 },
    { "op": "checkpoint", "name": "after_bid" },
    {
      "op": "assert_value",
      "checkpoint": "after_bid",
      "path": "harness_state.pending_actions",
      "comparator": "gt",
      "expected": 0
    },
    { "op": "wait_frames", "frames": 20 },
    { "op": "checkpoint", "name": "after_resolve" },
    {
      "op": "assert_value",
      "checkpoint": "after_resolve",
      "path": "harness_state.pending_actions",
      "comparator": "eq",
      "expected": 0
    },
    { "op": "quit" }
  ]
}
